{
  "name": "onlabel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/lib/onlabel/verify.test.ts && tsx src/lib/onlabel/provenance.test.ts && tsx src/lib/onlabel/tool.test.ts && tsx src/lib/onlabel/verifyClaims.test.ts && tsx src/lib/onlabel/reconcile.test.ts && tsx evals/check-golden.ts",
    "check:golden": "tsx evals/check-golden.ts",
    "check:live": "node --env-file=.env --import tsx scripts/live-check.ts",
    "eval": "tsx evals/run-eval.ts",
    "eval:live": "node --env-file=.env --import tsx evals/run-eval.ts --live",
    "collect": "node --env-file=.env --import tsx evals/collect.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.204",
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
